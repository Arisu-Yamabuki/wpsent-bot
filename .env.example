# ── WPSent Credentials (from wpsent.xyz dashboard) ──
WPSENT_CLIENT_ID=your_client_id_here
WPSENT_API_KEY=your_secret_key_here
WPSENT_BASE_URL=https://wpsent.xyz

# ── Groq API ──
# Get your key at: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── AI Behavior ──
# Available models: llama3-8b-8192 | llama3-70b-8192 | mixtral-8x7b-32768 | gemma2-9b-it
GROQ_MODEL=llama3-8b-8192
SYSTEM_PROMPT=You are a helpful WhatsApp assistant. Keep replies concise and friendly.

# ── Upstash Redis (from upstash.com) ──
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# ── Conversation Memory ──
MAX_HISTORY=500

# ── Optional Security ──
WEBHOOK_SECRET=
